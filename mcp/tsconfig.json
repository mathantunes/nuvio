{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "drizzle-orm": ["./node_modules/drizzle-orm"],
      "drizzle-orm/*": ["./node_modules/drizzle-orm/*"]
    },
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": ".."
  },
  "include": ["src/**/*.ts", "../web/src/db/schema.ts"]
}
